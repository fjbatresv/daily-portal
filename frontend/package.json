{
  "name": "@daily-portal/frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "ng build",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\"",
    "lint": "eslint \"src/**/*.{ts,html}\"",
    "start": "ng serve",
    "test": "ng test --watch=false --browsers=ChromeHeadless"
  },
  "dependencies": {
    "@angular/common": "22.0.4",
    "@angular/compiler": "22.0.4",
    "@angular/core": "22.0.4",
    "@angular/forms": "22.0.4",
    "@angular/platform-browser": "22.0.4",
    "@angular/router": "22.0.4",
    "@tailwindcss/postcss": "4.3.2",
    "@tabler/icons-webfont": "3.35.0",
    "rxjs": "7.8.2",
    "tailwindcss": "4.3.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.0"
  },
  "devDependencies": {
    "@angular/build": "22.0.4",
    "@angular/cli": "22.0.4",
    "@angular/compiler-cli": "22.0.4",
    "@eslint/js": "9.39.4",
    "@types/jasmine": "6.0.0",
    "angular-eslint": "22.0.0",
    "eslint": "9.39.4",
    "jasmine-core": "6.3.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  }
}
