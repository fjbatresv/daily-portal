# Runtime
NODE_ENV=production
PORT=3000
HOST_PORT=8090
SERVE_STATIC=true
TZ=America/Guatemala

# SQLite
SQLITE_PATH=/app/data/portal.db
SQLITE_SCHEMA_PATH=/app/db/schema.sql

# Redis
REDIS_URL=redis://redis:6379

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Jira
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# GitHub
GITHUB_TOKEN=
GITHUB_USERNAME=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_IDS=primary

# Slack
SLACK_USER_TOKEN=
SLACK_USER_ID=

# Scheduler
MORNING_DIGEST_CRON="0 8 * * *"
